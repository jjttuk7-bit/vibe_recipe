# =============================================================
# 바이브 레시피 환경 변수 (server-only)
# =============================================================
# 정책 (헌법 §8.5 + ADR D-011):
# - 이 파일에 있는 키는 모두 server-only. NEXT_PUBLIC_* 접두사 사용 금지.
# - NEXT_PUBLIC_* 접두사가 붙으면 Next.js가 클라이언트 번들에 포함시킨다.
#   ANTHROPIC_API_KEY / SUPABASE_SERVICE_ROLE_KEY / UPSTASH_REDIS_REST_TOKEN
#   는 클라이언트에 노출되면 사용자 한 명의 키로 전 세계가 비용을 태운다.
# - 실제 값은 .env.local 에만 둔다 (.gitignore 에 포함).
# - lib/env.ts 는 server-only 패키지로 import 그래프 강제 차단.
# =============================================================

# --- Anthropic (엔진) ---
# ENGINE.md §1: 기본 모델은 짧은 구조화 JSON에 최적화된 Haiku.
# VIBE_RECIPE_MODEL 로 일시 교체 가능 (예: claude-sonnet-4-6).
ANTHROPIC_API_KEY=
VIBE_RECIPE_MODEL=claude-haiku-4-5-20251001

# --- Upstash Redis (Rate Limit, P0 필수) ---
# /api/* 라우트의 IP 기반 rate limit 백엔드.
# 부재 시 lib/env.ts 가 명시적 에러를 던진다 (조용한 fallback 금지).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Supabase (영속, D-007 필수) ---
# localStorage 금지. RuntimeLog/Fingerprint 는 해자 자산이므로 서버 영속만 허용.
# URL은 공개돼도 무방하지만, anon/service-role 키는 절대 NEXT_PUBLIC_* 으로 노출 금지.
# service-role 은 RLS 우회용이라 서버 전용 라우트에서만 사용.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Rate Limit 파라미터 (선택, 미설정 시 lib/ratelimit.ts 기본값) ---
# 분당 요청 수 (sliding window). 빈 값이면 60.
# RATE_LIMIT_PER_MINUTE=60
